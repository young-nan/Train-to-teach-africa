# =============================================================================
# Train To Teach Africa — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for local development.
# The real values live in Vercel Project Settings > Environment Variables.
#
# RULE: Anything starting with VITE_ is exposed to the browser.
#       Secrets (Paystack secret key, Supabase service role) MUST NOT carry
#       the VITE_ prefix and are only consumed inside Edge Functions.
# =============================================================================

# --- Supabase (public — safe to expose) -------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Paystack (public key — safe to expose) ---------------------------------
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# --- Site config -------------------------------------------------------------
VITE_SITE_URL=https://traintoteachafrica.org
VITE_APP_URL=https://app.traintoteachafrica.org

# --- FX benchmark (consumed at build time by pricing config) ----------------
# Used to display USD-equivalent next to NGN prices on African curriculum.
# Update this value at each scheduled FX rebenchmark.
VITE_FX_NGN_PER_USD=1370.26
VITE_FX_BENCHMARK_DATE=2026-05-05

# =============================================================================
# Server-only secrets (never prefixed with VITE_) — for Edge Functions
# =============================================================================
SUPABASE_SERVICE_ROLE_KEY=eyJ...
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx
