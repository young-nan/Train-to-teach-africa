# =============================================================================
# Train To Teach Africa — Environment Configuration
# Version 2.0 · May 2026
# =============================================================================
#
# USAGE
# ─────
# Local development:
#   cp .env.example .env.local
#   Fill in the values marked [REQUIRED] before running `npm run dev`.
#
# Production (Vercel):
#   Set these in Vercel Dashboard → Project → Settings → Environment Variables.
#   Do NOT commit .env.local to git.
#
# Supabase Edge Functions:
#   Set the server-only secrets in Supabase Dashboard → Project → Settings →
#   Edge Function Secrets (not in Vercel).
#
# RULES
# ─────
# 1. Variables prefixed VITE_ are compiled into the client bundle — visible
#    to anyone who inspects the network or JS source. Only safe public keys.
# 2. Server-only secrets (service role key, webhook secrets, API tokens) must
#    NEVER carry the VITE_ prefix. They live in Edge Function secrets only.
# 3. SUPABASE_SERVICE_ROLE_KEY and SUPABASE_JWT_SECRET are auto-injected into
#    Edge Functions by Supabase — you don't set them in Vercel.
#
# =============================================================================


# ── Supabase (public — safe to expose) ───────────────────────────────────────
# Find these in Supabase Dashboard → Project → Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co       # [REQUIRED]
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...              # [REQUIRED]


# ── Paystack (public key — safe to expose) ───────────────────────────────────
# Use pk_test_xxx for development, pk_live_xxx for production.

VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxx                          # [REQUIRED]


# ── Site URLs ─────────────────────────────────────────────────────────────────
# Used by the client for OG tags and deep links in WhatsApp messages.

VITE_SITE_URL=https://traintoteachafrica.org
VITE_APP_URL=https://app.traintoteachafrica.org


# ── FX benchmark (compiled at build time) ────────────────────────────────────
# The NGN/USD rate used to show USD-equivalent next to NGN prices on the
# pricing page. Update at each scheduled FX rebenchmark (quarterly).
# Note: this is purely informational — all billing is in Naira for African
# curriculum and USD for International. No payments use this rate.

VITE_FX_NGN_PER_USD=1370.26
VITE_FX_BENCHMARK_DATE=2026-05-05


# =============================================================================
# Server-only secrets — Edge Functions ONLY (Supabase Secrets panel)
# =============================================================================
# These are NOT set in Vercel. Set them in:
#   Supabase Dashboard → Project → Settings → Edge Function Secrets
#
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, and
# SUPABASE_JWT_SECRET are auto-injected by Supabase and do not need to be
# set manually unless you're running a local Supabase instance.

# Paystack (server-side)
PAYSTACK_SECRET_KEY=sk_test_xxx                              # [REQUIRED for payments]
PAYSTACK_WEBHOOK_SECRET=whsec_xxx                           # [REQUIRED for payment webhooks]

# Meta WhatsApp Cloud API
META_WABA_PHONE_NUMBER_ID=12345678901234                    # [REQUIRED for WhatsApp sends]
META_WHATSAPP_TOKEN=EAAxxxxxxxx                             # [REQUIRED for WhatsApp sends]
META_APP_SECRET=abc123def456                                # [REQUIRED for webhook HMAC verification]
META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token          # [REQUIRED — any string you choose]

# Termii SMS (optional — enables SMS fallback when WhatsApp fails)
TERMII_API_KEY=TLxxxxxxxxxx                                 # [OPTIONAL]

# App URL (used by nightly-digest to build deep links in WhatsApp messages)
APP_BASE_URL=https://traintoteachafrica.org

# Site URL (used by some edge functions for redirects)
SITE_URL=https://traintoteachafrica.org

# Supabase pg_cron → nightly-digest configuration
# After applying migration 0013, run these in Supabase SQL Editor:
#   alter database postgres set app.supabase_url  = 'https://YOUR_REF.supabase.co';
#   alter database postgres set app.service_role_key = 'YOUR_SERVICE_ROLE_KEY';


# =============================================================================
# Optional / future
# =============================================================================

# Sentry DSN (error tracking — not yet wired)
# VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# PostHog (analytics — not yet wired)
# VITE_POSTHOG_KEY=phc_xxx
# VITE_POSTHOG_HOST=https://app.posthog.com
